# Email (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=

# Analytics (Umami) — optional
# The script URL provided by your Umami instance
UMAMI_DOMAIN=
# The website ID from your Umami dashboard
UMAMI_SITE_ID=

# Live visitors (Socket.io) — optional
# The URL of your WebSocket server, e.g. http://localhost:4000
NEXT_PUBLIC_WS_URL=
